            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"sts:AssumeRoleWithWebIdentity\",\n      \"Principal\": {\n        \"Federated\": \"arn:aws:iam::872515281253:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/73A00F18F7598DA5CDEDF68C996EFFC8\"\n      },\n      \"Condition\": {\n        \"StringEquals\": {\n          \"oidc.eks.us-east-1.amazonaws.com/id/73A00F18F7598DA5CDEDF68C996EFFC8:aud\": \"sts.amazonaws.com\",\n          \"oidc.eks.us-east-1.amazonaws.com/id/73A00F18F7598DA5CDEDF68C996EFFC8:sub\": \"system:serviceaccount:external-secrets:external-secrets-sa\"\n        }\n      }\n    }\n  ]\n}",
